{
  "name": "@endge/nova-ui-kit",
  "private": false,
  "version": "0.1.1",
  "type": "module",
  "module": "./dist/nova-ui-kit.js",
  "types": "./dist/index.d.ts",
  "web-types": "./web-types.json",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/nova-ui-kit.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "web-types.json"
  ],
  "scripts": {
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "dev": "vite build --watch",
    "dev:watch": "vite build --watch",
    "build": "vite build",
    "test": "vitest"
  },
  "dependencies": {
    "@endge/nova": "workspace:*",
    "@endge/utils": "workspace:*"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/tsconfig": "^0.7.0",
    "rimraf": "^6.0.1",
    "typescript": "~5.7.3",
    "vite": "^6.1.0",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.2.0"
  }
}
